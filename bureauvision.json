    "filename": "index.html",
    "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>IM2026 Bureauvision: A Day in the Life</title>\n    <style>\n        body {\n            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;\n            background: #f4f6f9;\n            margin: 0;\n            padding: 0;\n            color: #333;\n            overflow: hidden;\n        }\n        #bg-video {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100vw;\n            height: 100vh;\n            object-fit: cover;\n            opacity: 0.05;\n            z-index: 1;\n            pointer-events: none;\n        }\n        .container {\n            position: relative;\n            z-index: 10;\n            max-width: 600px;\n            margin: 10vh auto;\n            background: white;\n            border-radius: 8px;\n            box-shadow: 0 4px 20px rgba(0,0,0,0.05);\n            overflow: hidden;\n        }\n        .header {\n            background: #005ea5;\n            color: white;\n            padding: 1.5rem;\n            text-align: center;\n        }\n        .header h1 {\n            margin: 0;\n            font-size: 1.2rem;\n            font-weight: 500;\n            letter-spacing: 1px;\n        }\n        .content {\n            padding: 2rem;\n            min-height: 250px;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n        }\n        .task-text {\n            font-size: 1.1rem;\n            margin-bottom: 2rem;\n            text-align: center;\n            font-weight: 500;\n        }\n        .btn-group {\n            display: flex;\n            flex-direction: column;\n            gap: 10px;\n        }\n        button {\n            padding: 12px;\n            border: none;\n            border-radius: 4px;\n            font-size: 1rem;\n            cursor: pointer;\n            transition: all 0.2s;\n            font-weight: bold;\n        }\n        .btn-primary {\n            background: #005ea5;\n            color: white;\n        }\n        .btn-primary:hover {\n            background: #004070;\n        }\n        .btn-secondary {\n            background: #e0e6ed;\n            color: #333;\n        }\n        .btn-secondary:hover {\n            background: #cbd4e0;\n        }\n        .system-msg {\n            text-align: center;\n            color: #005ea5;\n            font-style: italic;\n            margin-top: 1rem;\n            min-height: 24px;\n            font-size: 0.9rem;\n        }\n        \n        /* Phase 2 specific */\n        #phase2 {\n            display: none;\n            background: #fff5f5;\n            border: 2px solid #e53e3e;\n        }\n        .dilemma-title {\n            color: #e53e3e;\n            font-weight: bold;\n            margin-bottom: 1rem;\n            text-align: center;\n        }\n        #justification-area {\n            display: none;\n            margin-top: 1rem;\n            flex-direction: column;\n        }\n        textarea {\n            width: 100%;\n            box-sizing: border-box;\n            padding: 10px;\n            height: 80px;\n            border: 1px solid #e53e3e;\n            resize: none;\n            font-family: monospace;\n            outline: none;\n        }\n        \n        /* Phase 3 specific */\n        #phase3 {\n            display: none;\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100vw;\n            height: 100vh;\n            background: black;\n            z-index: 100;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n        }\n        .msg-line {\n            color: white;\n            font-size: 1.5rem;\n            margin: 1rem;\n            opacity: 0;\n            transition: opacity 2s;\n            text-align: center;\n            letter-spacing: 2px;\n        }\n        \n        #start-screen {\n            position: absolute;\n            inset: 0;\n            background: white;\n            z-index: 50;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            flex-direction: column;\n        }\n    </style>\n</head>\n<body>\n\n    <!-- Audio/Video Hooks (Placeholders) -->\n    <video id=\"bg-video\" loop muted playsinline>\n        <source src=\"video/data-flow-loop.mp4\" type=\"video/mp4\">\n    </video>\n    <audio id=\"audio-click\" src=\"audio/ui-click.mp3\"></audio>\n    <audio id=\"audio-ambient\" src=\"audio/ambient-loop.mp3\" loop></audio>\n    <audio id=\"audio-drone\" src=\"audio/ethical-dilemma-drone.mp3\" loop></audio>\n    <audio id=\"audio-halt\" src=\"audio/system-halt.wav\"></audio>\n\n    <div class=\"container\" id=\"app-container\">\n        <!-- Start Screen to initialize audio context -->\n        <div id=\"start-screen\">\n            <h2>APS System Portal 2036</h2>\n            <button class=\"btn-primary\" onclick=\"startApp()\">Login to Dashboard</button>\n        </div>\n\n        <div class=\"header\">\n            <h1>APS BUREAUVISION</h1>\n        </div>\n        \n        <!-- Phase 1 -->\n        <div class=\"content\" id=\"phase1\">\n            <div class=\"task-text\" id=\"task-desc\"></div>\n            <div class=\"btn-group\" id=\"task-btns\"></div>\n            <div class=\"system-msg\" id=\"system-msg\"></div>\n        </div>\n\n        <!-- Phase 2 -->\n        <div class=\"content\" id=\"phase2\">\n            <div class=\"dilemma-title\">CRITICAL ALERT: UNPRECEDENTED ETHICAL DILEMMA</div>\n            <div class=\"task-text\">Housing allocation algorithm conflict detected. Automated logic insufficient. Please provide your human policy judgement.</div>\n            <div class=\"btn-group\" id=\"dilemma-btns\">\n                <button class=\"btn-primary\" onclick=\"showInput()\">Override Algorithm</button>\n                <button class=\"btn-secondary\" onclick=\"showInput()\">Request Human Review Board</button>\n                <button class=\"btn-secondary\" onclick=\"showInput()\">Accept AI Recommendation</button>\n            </div>\n            <div id=\"justification-area\">\n                <label style=\"font-weight:bold; margin-bottom:5px; color:#e53e3e;\">Justify your decision:</label>\n                <textarea id=\"human-input\" placeholder=\"Type here...\"></textarea>\n            </div>\n        </div>\n    </div>\n\n    <!-- Phase 3 -->\n    <div id=\"phase3\">\n        <div class=\"msg-line\" id=\"msg1\">System Halted.</div>\n        <div class=\"msg-line\" id=\"msg2\">You have forgotten how to think.</div>\n        <div class=\"msg-line\" id=\"msg3\">AI should augment judgement, not replace it.</div>\n        <div class=\"msg-line\" id=\"msg4\" style=\"font-size: 1rem; color: #888; margin-top: 3rem;\">An entry for IM2026 Bureauvision.</div>\n    </div>\n\n    <script>\n        const tasks = [\n            {\n                desc: \"Meeting scheduled. Brief required.\",\n                options: [\n                    { label: \"Auto-Resolve with AI\", type: \"ai\", msg: \"AI has generated and distributed the brief.\" },\n                    { label: \"Draft Manually\", type: \"manual\", msg: \"Manual drafting disabled for efficiency. AI has generated and distributed the brief.\" }\n                ]\n            },\n            {\n                desc: \"Senate Estimates approaching.\",\n                options: [\n                    { label: \"Auto-Resolve with AI\", type: \"ai\", msg: \"AI has predicted all questions and drafted responses.\" },\n                    { label: \"Consult Subject Matter Experts\", type: \"manual\", msg: \"SMEs are currently engaged. AI has predicted all questions and drafted responses.\" }\n                ]\n            },\n            {\n                desc: \"Stakeholder consultation needed.\",\n                options: [\n                    { label: \"Auto-Resolve with AI\", type: \"ai\", msg: \"AI has generated synthetic citizens and synthesised feedback.\" }\n                ]\n            },\n            {\n                desc: \"Cabinet submission pending.\",\n                options: [\n                    { label: \"Auto-Resolve with AI\", type: \"ai\", msg: \"AI drafted submission while you slept.\" }\n                ]\n            }\n        ];\n\n        let currentTask = 0;\n        let p3Triggered = false;\n\n        function playClick() {\n            let audio = document.getElementById('audio-click');\n            audio.currentTime = 0;\n            audio.play().catch(e => console.log('Audio playback bypassed: ', e));\n        }\n\n        function startApp() {\n            playClick();\n            document.getElementById('start-screen').style.display = 'none';\n            document.getElementById('bg-video').play().catch(e => console.log(e));\n            document.getElementById('audio-ambient').play().catch(e => console.log(e));\n            loadTask();\n        }\n\n        function loadTask() {\n            if (currentTask >= tasks.length) {\n                initPhase2();\n                return;\n            }\n            \n            document.getElementById('system-msg').innerText = '';\n            const task = tasks[currentTask];\n            document.getElementById('task-desc').innerText = task.desc;\n            \n            const btnContainer = document.getElementById('task-btns');\n            btnContainer.innerHTML = '';\n            \n            task.options.forEach(opt => {\n                const btn = document.createElement('button');\n                btn.className = opt.type === 'ai' ? 'btn-primary' : 'btn-secondary';\n                btn.innerText = opt.label;\n                btn.onclick = () => handleChoice(opt);\n                btnContainer.appendChild(btn);\n            });\n        }\n\n        function handleChoice(option) {\n            playClick();\n            const btnContainer = document.getElementById('task-btns');\n            btnContainer.innerHTML = ''; // disable further clicks\n            \n            const msgEl = document.getElementById('system-msg');\n            msgEl.innerText = option.msg;\n            \n            setTimeout(() => {\n                currentTask++;\n                loadTask();\n            }, 2500);\n        }\n\n        function initPhase2() {\n            document.getElementById('phase1').style.display = 'none';\n            document.getElementById('phase2').style.display = 'block';\n            \n            // Swap audio/video\n            document.getElementById('audio-ambient').pause();\n            document.getElementById('audio-drone').play().catch(e => console.log(e));\n            \n            const video = document.getElementById('bg-video');\n            video.src = \"video/glitch-transition.mp4\";\n            video.play().catch(e => console.log(e));\n            video.style.opacity = \"0.3\";\n        }\n\n        function showInput() {\n            playClick();\n            document.getElementById('dilemma-btns').style.display = 'none';\n            document.getElementById('justification-area').style.display = 'flex';\n            \n            const inputEl = document.getElementById('human-input');\n            inputEl.focus();\n            \n            inputEl.addEventListener('input', (e) => {\n                // Auto-delete simulation (paralysis)\n                setTimeout(() => {\n                    e.target.value = '';\n                }, 50);\n                \n                // Trigger sequence to Phase 3 on first keystroke\n                if (!p3Triggered) {\n                    p3Triggered = true;\n                    setTimeout(initPhase3, 5000);\n                }\n            });\n        }\n\n        function initPhase3() {\n            document.getElementById('audio-drone').pause();\n            let haltSnd = document.getElementById('audio-halt');\n            haltSnd.play().catch(e => console.log(e));\n            \n            document.getElementById('app-container').style.display = 'none';\n            document.getElementById('bg-video').style.display = 'none';\n            \n            const p3 = document.getElementById('phase3');\n            p3.style.display = 'flex';\n            \n            setTimeout(() => document.getElementById('msg1').style.opacity = 1, 1000);\n            setTimeout(() => document.getElementById('msg2').style.opacity = 1, 3500);\n            setTimeout(() => document.getElementById('msg3').style.opacity = 1, 6500);\n            setTimeout(() => document.getElementById('msg4').style.opacity = 1, 9500);\n        }\n    </script>\n</body>\n</html>"
  }
]